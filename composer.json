{
	"name": "latz/writing-status",
	"description": "Mark draft posts by completion status (complete/incomplete) with priority levels",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Latz",
			"homepage": "https://elektroelch.de"
		}
	],
	"require-dev": {
		"phpunit/phpunit": "^9.5",
		"wp-coding-standards/wpcs": "^3.3",
		"szepeviktor/phpstan-wordpress": "^2.0"
	},
	"scripts": {
		"test": "phpunit --testsuite unit",
		"test:unit": "phpunit --testsuite unit",
		"test:integration": "WP_TESTS_DIR=/tmp/wordpress-tests-lib php vendor/bin/phpunit --testsuite integration --bootstrap tests/integration-bootstrap.php",
		"install-wp-tests": "bash bin/install-wp-tests.sh"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
